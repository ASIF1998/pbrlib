#pragma once

#include <vulkan/vulkan.h>

#include <filesystem>

namespace pbrlib::backend::priv
{
    constexpr uint32_t EngineVersion = VK_MAKE_VERSION(
        @PBRLIB_ENGINE_VERSION_MAJOR@,
        @PBRLIB_ENGINE_VERSION_MINOR@,
        @PBRLIB_ENGINE_VERSION_PATCH@
    );

    constexpr uint32_t VulkanVersion = VK_MAKE_VERSION(
        @PBRLIB_VULKAN_VERSION_MAJOR@,
        @PBRLIB_VULKAN_VERSION_MINOR@,
        @PBRLIB_VULKAN_VERSION_PATCH@
    );
}

namespace pbrlib::backend::priv
{
    const std::filesystem::path PathToRoot = "@PBRLIB_PATH_TO_ROOT@";
}
